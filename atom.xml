  <entry>
    <title>向こう</title>
    <link href="https://harumi.cc/vocabulary/mu/mukou/"/>
    <id>https://harumi.cc/vocabulary/mu/mukou/</id>
    <published>2025-07-04T11:22:22.000Z</published>
    <updated>2025-07-04T11:22:51.542Z</updated>
    
