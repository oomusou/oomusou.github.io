  <entry>
    <title>注目</title>
    <link href="https://yabai.tw/nihonngo/vocabulary/chu/chuumoku/"/>
    <id>https://yabai.tw/nihonngo/vocabulary/chu/chuumoku/</id>
    <published>2024-07-31T00:04:43.000Z</published>
