    <category term="比較口語" scheme="https://yabai.tw/tags/%E6%AF%94%E8%BC%83%E5%8F%A3%E8%AA%9E/"/>
    
  </entry>
  
  <entry>
    <title>そっか = そうですか (是喔)</title>
    <link href="https://yabai.tw/nihonngo/spoken/so/sokka/"/>
    <id>https://yabai.tw/nihonngo/spoken/so/sokka/</id>
