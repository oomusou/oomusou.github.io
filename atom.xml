    <title>N は いA (普通体現在肯定)</title>
    <link href="https://yabai.tw/nihonngo/grammar/adjective/i/normal/present-positive/"/>
    <id>https://yabai.tw/nihonngo/grammar/adjective/i/normal/present-positive/</id>
    <published>2024-03-25T01:57:40.000Z</published>
    <updated>2024-03-25T01:58:27.418Z</updated>
    
