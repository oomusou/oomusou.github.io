  <entry>
    <title>が (中立敘述)</title>
    <link href="https://harumi.cc/grammar/jyoshi/kaku/ga/ga01/"/>
    <id>https://harumi.cc/grammar/jyoshi/kaku/ga/ga01/</id>
    <published>2025-05-04T23:32:17.000Z</published>
    <updated>2025-05-04T23:34:59.256Z</updated>
    
