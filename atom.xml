  <entry>
    <title>ゆっくり (悠閒地)</title>
    <link href="https://yabai.tw/nihonngo/grammar/adverb/yu/yukkuri/yukkuri02/"/>
    <id>https://yabai.tw/nihonngo/grammar/adverb/yu/yukkuri/yukkuri02/</id>
    <published>2024-08-06T00:05:16.000Z</published>
    <updated>2024-08-06T08:37:18.764Z</updated>
    
