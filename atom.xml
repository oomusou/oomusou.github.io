  <entry>
    <title>おっす = お疲れ様です (您辛苦了)</title>
    <link href="https://harumi.cc/nihonngo/kougo/o/ossu/"/>
    <id>https://harumi.cc/nihonngo/kougo/o/ossu/</id>
    <published>2025-04-04T11:11:48.000Z</published>
