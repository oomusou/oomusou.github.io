    <category term="い形容詞" scheme="https://harumi.cc/tags/%E3%81%84%E5%BD%A2%E5%AE%B9%E8%A9%9E/"/>
    
    <category term="な形容詞" scheme="https://harumi.cc/tags/%E3%81%AA%E5%BD%A2%E5%AE%B9%E8%A9%9E/"/>
    
