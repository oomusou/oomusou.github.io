  <entry>
    <title>のびのび (悠閒地)</title>
    <link href="https://yabai.tw/nihonngo/grammar/adverb/no/nobinobi/"/>
    <id>https://yabai.tw/nihonngo/grammar/adverb/no/nobinobi/</id>
    <published>2024-08-25T10:22:14.000Z</published>
